@{
    ViewData["Title"] = "Помочь";
}

<section class="bg-danger py-5">
    <div class="container py-5 text-center text-white">
        <h1 class="display-4 fw-bold mb-3">Как вы можете помочь</h1>
        <p class="lead opacity-75">Каждый вклад — это спасённая жизнь</p>
    </div>
</section>

<section class="py-5">
    <div class="container py-4">
        <div class="row g-5">
            <!-- Adoption -->
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow">
                    <div class="card-body p-5">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <i class="bi bi-house-heart fs-1"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Забрать питомца</h3>
                        <p class="text-muted mb-4">
                            Самая большая помощь — подарить животному дом. У нас живут замечательные
                            кошки и собаки, которые мечтают о любящей семье.
                        </p>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Все животные здоровы и привиты</li>
                            <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Бесплатная консультация по уходу</li>
                            <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Поддержка после усыновления</li>
                        </ul>
                        <a href="pets.html" class="btn btn-success btn-lg rounded-pill px-4">
                            <i class="bi bi-search me-2"></i>Выбрать питомца
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow">
                    <div class="card-body p-5">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <i class="bi bi-wallet2 fs-1"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Пожертвование</h3>
                        <p class="text-muted mb-4">
                            Финансовая помощь идёт на корм, лечение, вакцинацию и содержание
                            животных. Любая сумма важна!
                        </p>

                        <!-- Quick Donate Buttons -->
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <button class="btn btn-outline-warning px-4">500 ₽</button>
                            <button class="btn btn-outline-warning px-4">1000 ₽</button>
                            <button class="btn btn-outline-warning px-4">2000 ₽</button>
                            <button class="btn btn-outline-warning px-4">5000 ₽</button>
                        </div>

                        <div class="input-group mb-4">
                            <input type="number" class="form-control form-control-lg" placeholder="Другая сумма">
                            <span class="input-group-text">₽</span>
                        </div>

                        <a href="#" class="btn btn-warning btn-lg text-white rounded-pill px-4 w-100">
                            <i class="bi bi-heart-fill me-2"></i>Пожертвовать
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container py-4">
        <h2 class="display-6 fw-bold text-center mb-5">Другие способы помочь</h2>

        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-people fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Стать волонтёром</h5>
                        <p class="text-muted small mb-3">
                            Гуляйте с собаками, играйте с кошками, помогайте на мероприятиях.
                            Нужны руки и добрые сердца!
                        </p>
                        <a href="contact.html" class="btn btn-outline-primary btn-sm">Записаться</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-clock-history fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Временная опека</h5>
                        <p class="text-muted small mb-3">
                            Возьмите питомца на передержку, пока мы ищем ему постоянный дом.
                            Особенно нужна помощь с малышами.
                        </p>
                        <a href="contact.html" class="btn btn-outline-info btn-sm">Узнать больше</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-box-seam fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Материальная помощь</h5>
                        <p class="text-muted small mb-3">
                            Корм, лекарства, миски, лежанки, игрушки — всё это постоянно
                            нужно нашим подопечным.
                        </p>
                        <a href="#needs" class="btn btn-outline-danger btn-sm">Список нужд</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-car-front fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Помощь с транспортом</h5>
                        <p class="text-muted small mb-3">
                            Отвезите животное к ветеринару или новым хозяевам.
                            У нас не всегда есть такая возможность.
                        </p>
                        <a href="contact.html" class="btn btn-outline-success btn-sm">Предложить помощь</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-share fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Репост в соцсетях</h5>
                        <p class="text-muted small mb-3">
                            Расскажите о наших питомцах друзьям. Возможно, кто-то из них
                            давно мечтает о пушистом друге!
                        </p>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="#" class="btn btn-outline-secondary btn-sm"><i class="bi bi-telegram"></i></a>
                            <a href="#" class="btn btn-outline-secondary btn-sm"><i class="bi bi-whatsapp"></i></a>
                            <a href="#" class="btn btn-outline-secondary btn-sm"><i class="bi bi-instagram"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-calendar-event fs-3"></i>
                        </div>
                        <h5 class="fw-bold">Регулярное пожертвование</h5>
                        <p class="text-muted small mb-3">
                            Подпишитесь на ежемесячную помощь. Даже 300 рублей в месяц —
                            это корм для одного питомца!
                        </p>
                        <a href="#" class="btn btn-outline-warning btn-sm">Подписаться</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" id="needs">
    <div class="container py-4">
        <h2 class="display-6 fw-bold text-center mb-5">Что сейчас нужно</h2>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-warning text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Срочно нужно</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Сухой корм для собак (крупные породы)
                                <span class="badge bg-danger">Очень нужно</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Влажный корм для кошек
                                <span class="badge bg-danger">Очень нужно</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Антибиотики и противовоспалительные
                                <span class="badge bg-warning text-dark">Нужно</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Наполнитель для кошачьего туалета
                                <span class="badge bg-warning text-dark">Нужно</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-secondary text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Постоянные нужды</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Миски и поилки</li>
                            <li class="list-group-item">Поводки и ошейники</li>
                            <li class="list-group-item">Лежанки и домики для кошек</li>
                            <li class="list-group-item">Игрушки</li>
                            <li class="list-group-item">Пелёнки одноразовые</li>
                            <li class="list-group-item">Средства от блох и клещей</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <p class="text-muted">Привезти можно по адресу: <strong>г. Москва, ул. Лесная, 42</strong></p>
            <p class="text-muted">Ежедневно с 10:00 до 18:00</p>
        </div>
    </div>
</section>

<section class="py-5 bg-light" id="requisites_section">
    <div class="container py-4">
        <h2 class="display-6 fw-bold text-center mb-5">Реквизиты для перевода</h2>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <h6 class="fw-bold text-muted mb-2">Карта Сбербанк</h6>
                                <p class="fs-5 font-monospace mb-0">4276 1234 5678 9012</p>
                                <small class="text-muted">Получатель: Петрова А.И.</small>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold text-muted mb-2">Карта Тинькофф</h6>
                                <p class="fs-5 font-monospace mb-0">5536 9876 5432 1098</p>
                                <small class="text-muted">Получатель: Петрова А.И.</small>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold text-muted mb-2">ЮMoney</h6>
                                <p class="fs-5 font-monospace mb-0">410012345678901</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold text-muted mb-2">СБП (по номеру телефона)</h6>
                                <p class="fs-5 font-monospace mb-0">+7 999 123-45-67</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info mt-4" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    Мы регулярно публикуем отчёты о расходовании средств на нашей
                    <a href="#" class="alert-link">странице отчётов</a>.
                </div>
            </div>
        </div>
    </div>
</section>