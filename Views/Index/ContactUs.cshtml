@{
    ViewData["Title"] = "Свяжитесь с нами";
}

<section class="bg-primary py-5">
    <div class="container py-5 text-center text-white">
        <h1 class="display-4 fw-bold mb-3">Свяжитесь с нами</h1>
        <p class="lead opacity-75">Мы всегда рады ответить на ваши вопросы</p>
    </div>
</section>

<section class="py-5">
    <div class="container py-4">
        <div class="row g-5">
            <!-- Contact Info -->
            <div class="col-lg-5">
                <h3 class="fw-bold mb-4">Контактная информация</h3>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-geo-alt fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-4">
                        <h5 class="fw-bold">Адрес</h5>
                        <p class="text-muted mb-0">г. Москва, ул. Лесная, д. 42<br>
                            <small>Ближайшее метро: Белорусская</small></p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-telephone fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-4">
                        <h5 class="fw-bold">Телефон</h5>
                        <p class="text-muted mb-0">
                            <a href="tel:+79991234567" class="text-decoration-none">+7 (999) 123-45-67</a><br>
                            <small>Для записи на посещение</small>
                        </p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-telephone-forward fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-4">
                        <h5 class="fw-bold">Экстренная линия</h5>
                        <p class="text-muted mb-0">
                            <a href="tel:+79991234568" class="text-decoration-none">+7 (999) 123-45-68</a><br>
                            <small>Если нашли бездомное животное (круглосуточно)</small>
                        </p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-envelope fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-4">
                        <h5 class="fw-bold">Email</h5>
                        <p class="text-muted mb-0">
                            <a href="mailto:info@animalshelter.ru" class="text-decoration-none">info@animalshelter.ru</a>
                        </p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-clock fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-4">
                        <h5 class="fw-bold">Часы работы</h5>
                        <p class="text-muted mb-0">
                            Ежедневно: 10:00 — 18:00<br>
                            <small>Посещение по предварительной записи</small>
                        </p>
                    </div>
                </div>
                
                <h5 class="fw-bold mb-3 mt-5">Мы в социальных сетях</h5>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-primary rounded-circle" style="width: 45px; height: 45px;">
                        <i class="bi bi-telegram"></i>
                    </a>
                    <a href="#" class="btn btn-outline-danger rounded-circle" style="width: 45px; height: 45px;">
                        <i class="bi bi-instagram"></i>
                    </a>
                    <a href="#" class="btn btn-outline-success rounded-circle" style="width: 45px; height: 45px;">
                        <i class="bi bi-whatsapp"></i>
                    </a>
                    <a href="#" class="btn btn-outline-dark rounded-circle" style="width: 45px; height: 45px;">
                        <i class="bi bi-youtube"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card border-0 shadow">
                    <div class="card-body p-4 p-lg-5">
                        <h3 class="fw-bold mb-4">Напишите нам</h3>
                        <form>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Ваше имя *</label>
                                    <input type="text" class="form-control form-control-lg" placeholder="Иван Иванов" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Телефон *</label>
                                    <input type="tel" class="form-control form-control-lg" placeholder="+7 (___) ___-__-__" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control form-control-lg" placeholder="email@example.com">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Тема обращения *</label>
                                    <select class="form-select form-select-lg" required>
                                        <option value="">Выберите тему</option>
                                        <option value="adoption">Хочу забрать питомца</option>
                                        <option value="volunteer">Хочу стать волонтёром</option>
                                        <option value="foster">Временная опека</option>
                                        <option value="donation">Вопрос о пожертвованиях</option>
                                        <option value="found">Нашёл бездомное животное</option>
                                        <option value="other">Другое</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Сообщение *</label>
                                    <textarea class="form-control" rows="5" placeholder="Расскажите подробнее..." required></textarea>
                                </div>
                                <div class="col-12">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="consent" required>
                                        <label class="form-check-label small text-muted" for="consent">
                                            Я согласен на обработку персональных данных
                                        </label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-warning btn-lg text-white rounded-pill px-5">
                                        <i class="bi bi-send me-2"></i>Отправить сообщение
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h3 class="fw-bold text-center mb-4">Как нас найти</h3>
        <div class="rounded-4 overflow-hidden shadow">
            <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2245.0!2d37.6!3d55.75!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTXCsDQ1JzAwLjAiTiAzN8KwMzYnMDAuMCJF!5e0!3m2!1sru!2sru!4v1234567890"
                    width="100%"
                    height="400"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy">
            </iframe>
        </div>
        <div class="text-center mt-4">
            <a href="https://yandex.ru/maps" target="_blank" class="btn btn-outline-primary">
                <i class="bi bi-map me-2"></i>Открыть в Яндекс.Картах
            </a>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container py-4">
        <h3 class="fw-bold text-center mb-5">Часто задаваемые вопросы</h3>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item border-0 shadow-sm mb-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                Как записаться на посещение приюта?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                Позвоните нам по телефону +7 (999) 123-45-67 или напишите через форму на сайте.
                                Мы работаем ежедневно с 10:00 до 18:00 и принимаем посетителей по записи.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item border-0 shadow-sm mb-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                Какие документы нужны для усыновления?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                Паспорт гражданина РФ. Также мы попросим заполнить анкету и подписать
                                договор ответственного содержания животного.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item border-0 shadow-sm mb-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Усыновление платное?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                Нет, мы не берём плату за животных. Однако мы будем рады, если вы
                                сделаете добровольное пожертвование на содержание других подопечных.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <a href="faq.html" class="btn btn-outline-warning">Все вопросы и ответы</a>
                </div>
            </div>
        </div>
    </div>
</section>