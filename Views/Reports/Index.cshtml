@{
    ViewData["Title"] = "Отчеты";
}

<section class="bg-secondary py-5">
    <div class="container py-4 text-center text-white">
        <h1 class="display-4 fw-bold mb-3">Финансовые отчёты</h1>
        <p class="lead opacity-75">Прозрачность — наш главный принцип</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-shield-check me-2"></i>
                    Мы публикуем ежемесячные отчёты о всех поступлениях и расходах
                </div>
                <p class="lead text-muted">
                    Каждый рубль, который вы жертвуете, идёт на помощь животным.
                    Здесь вы можете посмотреть, как именно расходуются средства.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container">
        <h3 class="fw-bold text-center mb-4">Итоги 2024 года</h3>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-4">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-wallet2 fs-3"></i>
                        </div>
                        <h4 class="fw-bold text-success">2 450 000 ₽</h4>
                        <p class="text-muted mb-0">Собрано пожертвований</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-4">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-heart-pulse fs-3"></i>
                        </div>
                        <h4 class="fw-bold text-danger">980 000 ₽</h4>
                        <p class="text-muted mb-0">На ветеринарию</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-4">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-box fs-3"></i>
                        </div>
                        <h4 class="fw-bold text-warning">850 000 ₽</h4>
                        <p class="text-muted mb-0">На корм</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-4">
                        <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-house fs-3"></i>
                        </div>
                        <h4 class="fw-bold text-info">620 000 ₽</h4>
                        <p class="text-muted mb-0">На содержание</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

