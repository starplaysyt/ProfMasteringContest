<section class="bg-light py-5">
    <div class="container py-4">
        <h3 class="fw-bold text-center mb-5">На что идут пожертвования</h3>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <!-- Progress bars -->
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold">Ветеринария и лечение</span>
                                <span>40%</span>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-danger" style="width: 40%"></div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold">Корм</span>
                                <span>35%</span>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-warning" style="width: 35%"></div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold">Содержание приюта</span>
                                <span>15%</span>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-info" style="width: 15%"></div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold">Инвентарь и оборудование</span>
                                <span>7%</span>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-success" style="width: 7%"></div>
                            </div>
                        </div>

                        <div class="mb-0">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold">Административные расходы</span>
                                <span>3%</span>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-secondary" style="width: 3%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-warning py-5">
    <div class="container text-center text-white py-4">
        <h2 class="display-6 fw-bold mb-3">Помогите нам помогать</h2>
        <p class="lead opacity-75 mb-4">Каждый рубль — это спасённая жизнь</p>
        <a href="help.html" class="btn btn-light btn-lg rounded-pill px-5">
            <i class="bi bi-heart-fill me-2"></i>Сделать пожертвование
        </a>
    </div>
</section>