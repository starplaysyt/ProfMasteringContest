@{
    ViewData["Title"] = "Питомцы";
}


<section class="bg-light py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="index.html" class="text-decoration-none">Главная</a></li>
                <li class="breadcrumb-item active">Все питомцы</li>
            </ol>
        </nav>
    </div>
</section>

<section class="bg-warning py-5">
    <div class="container text-center text-white">
        <h1 class="display-4 fw-bold mb-3">Наши питомцы</h1>
        <p class="lead opacity-75">Найдите своего идеального друга среди наших подопечных</p>
    </div>
</section>

<section class="py-4 bg-light">
    <div class="container">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Тип животного</label>
                        <select class="form-select">
                            <option value="">Все</option>
                            <option value="dog">Собаки</option>
                            <option value="cat">Кошки</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Возраст</label>
                        <select class="form-select">
                            <option value="">Любой</option>
                            <option value="puppy">До 1 года</option>
                            <option value="young">1-3 года</option>
                            <option value="adult">3-7 лет</option>
                            <option value="senior">Старше 7 лет</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Размер</label>
                        <select class="form-select">
                            <option value="">Любой</option>
                            <option value="small">Маленький</option>
                            <option value="medium">Средний</option>
                            <option value="large">Крупный</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-warning text-white w-100">
                            <i class="bi bi-search me-2"></i>Найти
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <p class="text-muted mb-0">Найдено <strong>24</strong> питомца</p>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" style="width: auto;">
                    <option>Сначала новые</option>
                    <option>Сначала старые</option>
                    <option>По имени А-Я</option>
                </select>
            </div>
        </div>
    </div>
</section>

