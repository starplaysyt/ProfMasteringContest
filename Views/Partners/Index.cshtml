@{
    ViewData["Title"] = "Партнёры";
}

<section class="bg-warning py-5">
    <div class="container py-4">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-white mb-3">Наши партнёры</h1>
                <p class="lead text-white opacity-75 mb-0">
                    Благодарим компании, которые помогают нам заботиться о животных.
                    Вместе мы делаем мир добрее!
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                <a href="#become-partner" class="btn btn-light btn-lg rounded-pill px-4">
                    <i class="bi bi-handshake me-2"></i>Стать партнёром
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="bg-white py-4 border-bottom">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 col-6 mb-3 mb-md-0">
                <h3 class="fw-bold text-warning mb-0">25+</h3>
                <small class="text-muted">Партнёров</small>
            </div>
            <div class="col-md-3 col-6 mb-3 mb-md-0">
                <h3 class="fw-bold text-warning mb-0">8</h3>
                <small class="text-muted">Лет сотрудничества</small>
            </div>
            <div class="col-md-3 col-6">
                <h3 class="fw-bold text-warning mb-0">500+</h3>
                <small class="text-muted">Спасённых животных</small>
            </div>
            <div class="col-md-3 col-6">
                <h3 class="fw-bold text-warning mb-0">∞</h3>
                <small class="text-muted">Благодарности</small>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-5 flex-grow-1">
    <div class="container">

        <!-- Генеральные партнёры -->
        <div class="mb-5">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-warning text-white rounded-3 p-2 me-3">
                    <i class="bi bi-star-fill fs-4"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">Генеральные партнёры</h3>
                    <p class="text-muted mb-0">Основная поддержка приюта</p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-light rounded-4 p-4 mb-4">
                                <i class="bi bi-shop text-warning display-4"></i>
                            </div>
                            <h5 class="fw-bold">ЗооМаркет "Лапа"</h5>
                            <p class="text-muted small mb-3">
                                Крупнейшая сеть зоомагазинов. Обеспечивает приют кормами и товарами для животных.
                            </p>
                            <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2">
                                    <i class="bi bi-box-seam me-1"></i>Корма и товары
                                </span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-light rounded-4 p-4 mb-4">
                                <i class="bi bi-hospital text-success display-4"></i>
                            </div>
                            <h5 class="fw-bold">Ветклиника "Айболит"</h5>
                            <p class="text-muted small mb-3">
                                Сеть ветеринарных клиник. Бесплатное лечение и вакцинация наших подопечных.
                            </p>
                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">
                                    <i class="bi bi-heart-pulse me-1"></i>Ветеринария
                                </span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-light rounded-4 p-4 mb-4">
                                <i class="bi bi-building text-primary display-4"></i>
                            </div>
                            <h5 class="fw-bold">СтройГрупп</h5>
                            <p class="text-muted small mb-3">
                                Строительная компания. Помогла с ремонтом и расширением территории приюта.
                            </p>
                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                                    <i class="bi bi-tools me-1"></i>Инфраструктура
                                </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Информационные партнёры -->
        <div class="mb-5">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-info text-white rounded-3 p-2 me-3">
                    <i class="bi bi-megaphone-fill fs-4"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">Информационные партнёры</h3>
                    <p class="text-muted mb-0">Помогают рассказывать о нас</p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                                <i class="bi bi-broadcast text-danger fs-3"></i>
                            </div>
                            <h6 class="fw-bold">Радио "Добрая волна"</h6>
                            <p class="text-muted small mb-0">Эфиры о приюте</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                                <i class="bi bi-newspaper text-warning fs-3"></i>
                            </div>
                            <h6 class="fw-bold">Городской вестник</h6>
                            <p class="text-muted small mb-0">Публикации в газете</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                                <i class="bi bi-camera-reels text-success fs-3"></i>
                            </div>
                            <h6 class="fw-bold">ТВ "Регион"</h6>
                            <p class="text-muted small mb-0">Репортажи</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="card-body p-4 text-center">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                                <i class="bi bi-globe text-primary fs-3"></i>
                            </div>
                            <h6 class="fw-bold">Портал PetNews</h6>
                            <p class="text-muted small mb-0">Онлайн-публикации</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Партнёры по услугам -->
        <div class="mb-5">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-success text-white rounded-3 p-2 me-3">
                    <i class="bi bi-gear-fill fs-4"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">Партнёры по услугам</h3>
                    <p class="text-muted mb-0">Помощь профессионалов</p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-scissors text-warning fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Груминг-салон "Пушистик"</h6>
                                    <p class="text-muted small mb-0">Стрижка и уход</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-truck text-success fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Транспорт "ЗооТакси"</h6>
                                    <p class="text-muted small mb-0">Перевозка животных</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-info bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-camera text-info fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Фотостудия "Момент"</h6>
                                    <p class="text-muted small mb-0">Фото питомцев</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-danger bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-megaphone text-danger fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Агентство "Креатив"</h6>
                                    <p class="text-muted small mb-0">Реклама и дизайн</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-secondary bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-printer text-secondary fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Типография "Принт"</h6>
                                    <p class="text-muted small mb-0">Печать материалов</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-mortarboard text-primary fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Школа кинологов</h6>
                                    <p class="text-muted small mb-0">Дрессировка</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Become Partner CTA -->
        <div class="card border-0 shadow rounded-4 bg-white" id="become-partner">
            <div class="card-body p-5">
                <div class="row align-items-center">
                    <div class="col-lg-8 mb-4 mb-lg-0">
                        <h3 class="fw-bold mb-3">
                            <i class="bi bi-handshake text-warning me-2"></i>
                            Станьте нашим партнёром
                        </h3>
                        <p class="text-muted mb-3">
                            Мы открыты для сотрудничества с компаниями, которые разделяют наши ценности.
                            Вместе мы можем сделать больше для бездомных животных!
                        </p>
                        <div class="d-flex flex-wrap gap-3">
                            <div class="d-flex align-items-center text-muted">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <span>Логотип на сайте</span>
                            </div>
                            <div class="d-flex align-items-center text-muted">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <span>Упоминание в СМИ</span>
                            </div>
                            <div class="d-flex align-items-center text-muted">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <span>Сертификат партнёра</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 text-lg-end">
                        <a href="#" class="btn btn-warning btn-lg text-white rounded-pill px-4 me-2 mb-2">
                            <i class="bi bi-envelope me-2"></i>Написать нам
                        </a>
                        <a href="#" class="btn btn-outline-secondary btn-lg rounded-pill px-4 mb-2">
                            <i class="bi bi-telephone me-2"></i>Позвонить
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>