@{
    ViewData["Title"] = "Волонтёрство";
}

<section class="bg-dark py-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6 text-white">
                <h1 class="display-4 fw-bold mb-4">Стань волонтёром</h1>
                <p class="lead opacity-75 mb-4">
                    Присоединяйся к команде неравнодушных людей! Вместе мы можем
                    сделать жизнь бездомных животных лучше.
                </p>
                <a href="#apply" class="btn btn-warning btn-lg text-white rounded-pill px-4">
                    <i class="bi bi-pencil-square me-2"></i>Заполнить анкету
                </a>
            </div>
            <div class="col-lg-6 mt-4 mt-lg-0">
                <img src="https://images.unsplash.com/photo-1601758228041-f3b2795255f1?w=600"
                     alt="Волонтёры" class="img-fluid rounded-4 shadow-lg">
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Почему стоит стать волонтёром</h2>
            <p class="lead text-muted">Волонтёрство — это не только помощь, но и радость</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-heart fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Спасение жизней</h5>
                    <p class="text-muted mb-0">
                        Каждый час, проведённый в приюте, помогает животным
                        социализироваться и найти дом быстрее.
                    </p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-people fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Новые друзья</h5>
                    <p class="text-muted mb-0">
                        Познакомьтесь с единомышленниками — людьми, которые
                        разделяют вашу любовь к животным.
                    </p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-emoji-smile fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Позитивные эмоции</h5>
                    <p class="text-muted mb-0">
                        Общение с животными снимает стресс и дарит
                        море положительных эмоций.
                    </p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-mortarboard fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Новые знания</h5>
                    <p class="text-muted mb-0">
                        Научитесь ухаживать за животными, узнаете
                        о их поведении от профессионалов.
                    </p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-clock fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Гибкий график</h5>
                    <p class="text-muted mb-0">
                        Приходите, когда вам удобно. Даже пара часов
                        в неделю — это уже помощь!
                    </p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-file-text fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Рекомендации</h5>
                    <p class="text-muted mb-0">
                        Волонтёрский опыт украсит ваше резюме.
                        Выдаём официальные справки.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Чем можно заниматься</h2>
            <p class="lead text-muted">Выберите то, что вам по душе</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-success text-white rounded-3 p-3 me-3">
                                <i class="bi bi-compass fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Прогулки с собаками</h5>
                                <p class="text-muted mb-2">
                                    Выгул собак — важная часть их социализации.
                                    Прогулки длятся от 30 минут до 2 часов.
                                </p>
                                <span class="badge bg-success-subtle text-success">Физическая активность</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-info text-white rounded-3 p-3 me-3">
                                <i class="bi bi-controller fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Игры с животными</h5>
                                <p class="text-muted mb-2">
                                    Играйте с кошками и собаками, помогая им
                                    развиваться и привыкать к людям.
                                </p>
                                <span class="badge bg-info-subtle text-info">Для всех</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-warning text-white rounded-3 p-3 me-3">
                                <i class="bi bi-camera fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Фото и видео</h5>
                                <p class="text-muted mb-2">
                                    Снимайте питомцев для сайта и соцсетей.
                                    Хорошие фото помогают найти дом быстрее!
                                </p>
                                <span class="badge bg-warning-subtle text-warning">Творческая работа</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-primary text-white rounded-3 p-3 me-3">
                                <i class="bi bi-megaphone fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">SMM и продвижение</h5>
                                <p class="text-muted mb-2">
                                    Ведите наши соцсети, пишите посты,
                                    отвечайте на сообщения.
                                </p>
                                <span class="badge bg-primary-subtle text-primary">Удалённо</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-danger text-white rounded-3 p-3 me-3">
                                <i class="bi bi-car-front fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Транспортировка</h5>
                                <p class="text-muted mb-2">
                                    Отвезите питомца к ветеринару или
                                    доставьте к новым хозяевам.
                                </p>
                                <span class="badge bg-danger-subtle text-danger">Нужен автомобиль</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-secondary text-white rounded-3 p-3 me-3">
                                <i class="bi bi-tools fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Хозяйственная помощь</h5>
                                <p class="text-muted mb-2">
                                    Уборка вольеров, мелкий ремонт,
                                    помощь с благоустройством территории.
                                </p>
                                <span class="badge bg-secondary-subtle text-secondary">Физическая работа</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container py-4">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="display-5 fw-bold mb-4">Что нужно, чтобы стать волонтёром</h2>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 40px; height: 40px;">
                            <i class="bi bi-check-lg"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="fw-bold mb-1">Возраст от 16 лет</h6>
                        <p class="text-muted small mb-0">Для несовершеннолетних — согласие родителей</p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 40px; height: 40px;">
                            <i class="bi bi-check-lg"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="fw-bold mb-1">Любовь к животным</h6>
                        <p class="text-muted small mb-0">Терпение и готовность заботиться о них</p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 40px; height: 40px;">
                            <i class="bi bi-check-lg"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="fw-bold mb-1">Несколько часов в неделю</h6>
                        <p class="text-muted small mb-0">Минимум 2-3 часа, график свободный</p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 40px; height: 40px;">
                            <i class="bi bi-check-lg"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="fw-bold mb-1">Ответственность</h6>
                        <p class="text-muted small mb-0">Выполнение инструкций и правил приюта</p>
                    </div>
                </div>

                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    Опыт работы с животными не обязателен — мы всему научим!
                </div>
            </div>

            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1450778869180-41d0601e046e?w=600"
                     alt="Волонтёры с животными" class="img-fluid rounded-4 shadow">
            </div>
        </div>
    </div>
</section>

<section class="bg-warning py-5" id="apply">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-4 p-lg-5">
                        <h3 class="fw-bold text-center mb-4">Анкета волонтёра</h3>
                        <form>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Имя *</label>
                                    <input type="text" class="form-control form-control-lg" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Фамилия *</label>
                                    <input type="text" class="form-control form-control-lg" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Возраст *</label>
                                    <input type="number" class="form-control form-control-lg" min="16" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Телефон *</label>
                                    <input type="tel" class="form-control form-control-lg" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Email *</label>
                                    <input type="email" class="form-control form-control-lg" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Чем хотите заниматься? *</label>
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="walk">
                                                <label class="form-check-label" for="walk">Прогулки с собаками</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="play">
                                                <label class="form-check-label" for="play">Игры с животными</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="photo">
                                                <label class="form-check-label" for="photo">Фото/видео</label>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="smm">
                                                <label class="form-check-label" for="smm">SMM/тексты</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="transport">
                                                <label class="form-check-label" for="transport">Транспортировка</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="help">
                                                <label class="form-check-label" for="help">Хозяйственная помощь</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Сколько времени готовы уделять?</label>
                                    <select class="form-select form-select-lg">
                                        <option>2-3 часа в неделю</option>
                                        <option>4-6 часов в неделю</option>
                                        <option>Более 6 часов в неделю</option>
                                        <option>Пока не знаю</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Есть ли опыт с животными?</label>
                                    <textarea class="form-control" rows="3"
                                              placeholder="Расскажите о своих питомцах, опыте работы с животными..."></textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Откуда узнали о нас?</label>
                                    <select class="form-select">
                                        <option>Соцсети</option>
                                        <option>Поиск в интернете</option>
                                        <option>От друзей/знакомых</option>
                                        <option>СМИ</option>
                                        <option>Другое</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="agree" required>
                                        <label class="form-check-label" for="agree">
                                            Я согласен на обработку персональных данных
                                        </label>
                                    </div>
                                </div>
                                <div class="col-12 text-center">
                                    <button type="submit" class="btn btn-warning btn-lg text-white rounded-pill px-5">
                                        <i class="bi bi-send me-2"></i>Отправить анкету
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>