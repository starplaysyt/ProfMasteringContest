            <div class="toast-body" id="toast-body">Готово!</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ==================== DATA ====================
const availableTasks = [
    { id: '4', title: 'Уборка вольеров кошек', type: 'Уборка', priority: 'high', group: 'Группа Б', deadline: '16 июня 2025', hours: 3, icon: 'bi-bucket', color: 'danger', desc: 'Генеральная уборка секции кошек: мытьё вольеров, смена подстилок, дезинфекция.' },
    { id: '5', title: 'Выезд на выставку', type: 'Мероприятие', priority: 'high', group: 'Группа А', deadline: '20 июня 2025', hours: 6, icon: 'bi-flag', color: 'primary', desc: 'Сопровождение 4 собак на городскую выставку питомцев. Возможность найти хозяев!' },
    { id: '6', title: 'Фотосессия котят', type: 'Фото', priority: 'med', group: 'Группа А', deadline: '19 июня 2025', hours: 2, icon: 'bi-camera', color: 'info', desc: 'Сделать фотографии 6 котят для публикации на сайте приюта и соцсетях.' },
    { id: '7', title: 'Социализация щенков', type: 'Уход', priority: 'med', group: 'Группа Б', deadline: '22 июня 2025', hours: 4, icon: 'bi-heart', color: 'success', desc: 'Работа с помётом щенков (4 шт): игры, прикосновения, базовые команды.' },
    { id: '8', title: 'Ветеринарный осмотр (помощь)', type: 'Медицина', priority: 'high', group: 'Группа А', deadline: '14 июня 2025', hours: 3, icon: 'bi-heart-pulse', color: 'warning', desc: 'Помощь ветеринару во время планового осмотра 10 собак: фиксация животных, ведение записей.' },
    { id: '9', title: 'Закупка корма', type: 'Логистика', priority: 'low', group: 'Группа Б', deadline: '25 июня 2025', hours: 2, icon: 'bi-bag', color: 'secondary', desc: 'Поездка в зоомагазин, закупка корма по списку, доставка в приют.' },
];

const myTasks = [
    { id: '1', title: 'Кормление собак, вольер А', type: 'Уход', priority: 'high', status: 'inprogress', deadline: '14 июня 2025', progress: 60, icon: 'bi-droplet-fill', color: 'warning' },
    { id: '2', title: 'Выгул собак (утренний)', type: 'Выгул', priority: 'med', status: 'inprogress', deadline: '15 июня 2025', progress: 30, icon: 'bi-person-walking', color: 'success' },
    { id: '3', title: 'Фотосессия для кошек', type: 'Фото', priority: 'low', status: 'inprogress', deadline: '18 июня 2025', progress: 10, icon: 'bi-camera-fill', color: 'info' },
    { id: '10', title: 'Уборка вольеров (собаки)', type: 'Уборка', priority: 'high', status: 'overdue', deadline: '10 июня 2025', progress: 80, icon: 'bi-bucket-fill', color: 'danger' },
];

const reports = [
    { id: '21', task: 'Кормление собак, вольер А', date: '12 июня 2025', hours: 2, status: 'approved' },
    { id: '20', task: 'Выгул собак (вечерний)', date: '11 июня 2025', hours: 1.5, status: 'approved' },
    { id: '19', task: 'Фотосессия — Барон', date: '10 июня 2025', hours: 2, status: 'pending' },
    { id: '18', task: 'Социализация котёнка Серёги', date: '8 июня 2025', hours: 1, status: 'approved' },
    { id: '17', task: 'Уборка вольеров', date: '5 июня 2025', hours: 3, status: 'rejected' },
    { id: '16', task: 'Ветеринарный осмотр (помощь)', date: '3 июня 2025', hours: 2.5, status: 'approved' },
    { id: '15', task: 'Кормление собак, вольер А', date: '1 июня 2025', hours: 2, status: 'pending' },
];

// ==================== NAVIGATION ====================
let history = [];
let currentPage = 'dashboard';

const breadcrumbs = {
    dashboard: [{ label: 'Дашборд' }],
    notifications: [{ label: 'Дашборд', page: 'dashboard' }, { label: 'Уведомления' }],
    'tasks-available': [{ label: 'Дашборд', page: 'dashboard' }, { label: 'Доступные задачи' }],
    'tasks-my': [{ label: 'Дашборд', page: 'dashboard' }, { label: 'Мои задачи' }],
    'task-detail': [{ label: 'Дашборд', page: 'dashboard' }, { label: 'Задачи', page: 'tasks-my' }, { label: 'Детали задачи' }],
    'report-create': [{ label: 'Мои задачи', page: 'tasks-my' }, { label: 'Создание отчёта' }],
    reports: [{ label: 'Дашборд', page: 'dashboard' }, { label: 'История отчётов' }],
    'report-detail': [{ label: 'История отчётов', page: 'reports' }, { label: 'Отчёт' }],
    profile: [{ label: 'Дашборд', page: 'dashboard' }, { label: 'Мой профиль' }],
    'profile-edit': [{ label: 'Мой профиль', page: 'profile' }, { label: 'Редактирование' }],
};

function navigate(page, id) {
    history.push(currentPage);
    currentPage = page;
    showPage(page, id);
}

function goBack() {
    if (history.length > 0) {
        const prev = history.pop();
        currentPage = prev;
        showPage(prev);
    }
}

function showPage(page, id) {
    // Hide all pages
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));

    // Activate correct page
    const el = document.getElementById('page-' + page);
    if (el) el.classList.add('active');

    // Update sidebar active
    document.querySelectorAll('.sidebar-nav .nav-link').forEach(l => l.classList.remove('active'));
    const activeLink = document.querySelector(`.sidebar-nav .nav-link[data-page="${page}"]`);
    if (activeLink) activeLink.classList.add('active');

    // Breadcrumb
    const crumbs = breadcrumbs[page] || [{ label: page }];
    const bc = document.getElementById('breadcrumb');
    bc.innerHTML = crumbs.map((c, i) =>
        i < crumbs.length - 1
            ? `<li class="breadcrumb-item"><a href="#" onclick="navigate('${c.page}');return false;">${c.label}</a></li>`
            : `<li class="breadcrumb-item active">${c.label}</li>`
    ).join('');

    // Scroll to top
    window.scrollTo(0, 0);
    document.querySelector('.main-content').scrollTop = 0;

    // Page-specific init
    if (page === 'tasks-available') renderAvailableTasks();
    if (page === 'tasks-my') renderMyTasks('all');
    if (page === 'reports') renderReports();
    if (page === 'task-detail') loadTaskDetail(id);

    // Close mobile sidebar
    closeSidebar();
}

// ==================== SIDEBAR ====================
function openSidebar() {
    document.getElementById('sidebar').classList.add('show');
    document.getElementById('sidebarOverlay').style.display = 'block';
}
function closeSidebar() {
    document.getElementById('sidebar').classList.remove('show');
    document.getElementById('sidebarOverlay').style.display = 'none';
}

// Sidebar nav links
document.querySelectorAll('.sidebar-nav .nav-link').forEach(link => {
    link.addEventListener('click', function(e) {
        e.preventDefault();
        const page = this.dataset.page;
        if (page) navigate(page);
    });
});

// ==================== RENDER AVAILABLE TASKS ====================
function renderAvailableTasks() {
    const container = document.getElementById('available-tasks-list');
    const priorityLabel = { high: 'Высокий', med: 'Средний', low: 'Низкий' };
    const priorityClass = { high: 'badge-priority-high', med: 'badge-priority-med', low: 'badge-priority-low' };

    container.innerHTML = availableTasks.map(t => `
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm task-card h-100" onclick="navigate('task-detail','${t.id}')">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start gap-3">
                        <div class="bg-${t.color} bg-opacity-10 text-${t.color} rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                            <i class="bi ${t.icon} fs-5"></i>
                        </div>
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                                <h6 class="fw-bold mb-0">${t.title}</h6>
                                <span class="badge ${priorityClass[t.priority]} flex-shrink-0" style="font-size:0.65rem;">${priorityLabel[t.priority]}</span>
                            </div>
                            <p class="text-muted small mb-3">${t.desc}</p>
                            <div class="d-flex flex-wrap gap-3 small text-muted mb-3">
                                <span><i class="bi bi-calendar3 me-1 text-warning"></i>${t.deadline}</span>
                                <span><i class="bi bi-clock me-1 text-info"></i>${t.hours} ч.</span>
                                <span><i class="bi bi-people me-1 text-success"></i>${t.group}</span>
                            </div>
                            <div class="d-flex gap-2">
                                <span class="badge bg-light text-dark border">${t.type}</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 px-4 pb-4">
                    <button class="btn btn-warning text-white rounded-pill px-4 w-100" onclick="takeTask(event,'${t.id}','${t.title}')">
                        <i class="bi bi-plus-circle me-2"></i>Взять задачу
                    </button>
                </div>
            </div>
        </div>
    `).join('');
}

function takeTask(e, id, title) {
    e.stopPropagation();
    showToast(`Задача «${title}» добавлена в ваши задачи!`, 'success');
    setTimeout(() => navigate('tasks-my'), 800);
}

// ==================== RENDER MY TASKS ====================
function renderMyTasks(filter) {
    const container = document.getElementById('my-tasks-list');
    const priorityLabel = { high: 'Высокий', med: 'Средний', low: 'Низкий' };
    const priorityClass = { high: 'badge-priority-high', med: 'badge-priority-med', low: 'badge-priority-low' };
    const statusLabel = { inprogress: 'В работе', overdue: 'Просрочена', done: 'Завершена' };
    const statusClass = { inprogress: 'bg-warning text-dark', overdue: 'bg-danger', done: 'bg-success' };
    const barClass = { inprogress: 'bg-warning', overdue: 'bg-danger', done: 'bg-success' };

    const filtered = filter === 'all' ? myTasks : myTasks.filter(t => t.status === filter);

    if (filtered.length === 0) {
        container.innerHTML = `<div class="col-12 text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-3"></i>Задач не найдено</div>`;
        return;
    }

    container.innerHTML = filtered.map(t => `
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm task-card h-100" onclick="navigate('task-detail','${t.id}')">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start gap-3">
                        <div class="bg-${t.color} bg-opacity-10 text-${t.color} rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                            <i class="bi ${t.icon} fs-5"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                                <h6 class="fw-bold mb-0">${t.title}</h6>
                                <span class="badge ${statusClass[t.status]}" style="font-size:0.65rem;">${statusLabel[t.status]}</span>
                            </div>
                            <div class="d-flex flex-wrap gap-3 small text-muted mb-3">
                                <span><i class="bi bi-calendar3 me-1 ${t.status === 'overdue' ? 'text-danger' : 'text-warning'}"></i>${t.deadline}</span>
                                <span><i class="bi bi-tag me-1"></i>${t.type}</span>
                            </div>
                            <div class="mb-1 d-flex justify-content-between small">
                                <span class="text-muted">Прогресс</span>
                                <span class="fw-semibold">${t.progress}%</span>
                            </div>
                            <div class="progress">
                                <div class="progress-bar ${barClass[t.status]}" style="width:${t.progress}%"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 px-4 pb-4 d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" onclick="navigate('task-detail','${t.id}');event.stopPropagation()">
                        <i class="bi bi-eye me-1"></i>Детали
                    </button>
                    <button class="btn btn-warning text-white btn-sm rounded-pill px-3" onclick="navigate('report-create','${t.id}');event.stopPropagation()">
                        <i class="bi bi-file-earmark-text me-1"></i>Сдать отчёт
                    </button>
                </div>
            </div>
        </div>
    `).join('');
}

function filterMyTasks(filter, btn) {
    document.querySelectorAll('#page-tasks-my .nav-link').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderMyTasks(filter);
}

// ==================== TASK DETAIL ====================
function loadTaskDetail(id) {
    const allTasks = [...myTasks, ...availableTasks];
    const task = allTasks.find(t => t.id === id);
    if (!task) return;

    document.getElementById('task-detail-title').textContent = task.title;

    const isMine = myTasks.find(t => t.id === id);
    const actions = document.getElementById('task-detail-actions');
    if (isMine) {
        actions.innerHTML = `
            <button class="btn btn-warning text-white rounded-pill px-4" onclick="navigate('report-create','${id}')">
                <i class="bi bi-file-earmark-text me-2"></i>Сдать отчёт
            </button>`;
    } else {
        actions.innerHTML = `
            <button class="btn btn-success rounded-pill px-4" onclick="takeTask(event,'${id}','${task.title}')">
                <i class="bi bi-plus-circle me-2"></i>Взять задачу
            </button>`;
    }
    if (task.desc) document.getElementById('task-detail-desc').textContent = task.desc;
    if (task.deadline) document.getElementById('task-detail-deadline').textContent = task.deadline;
}

// ==================== RENDER REPORTS ====================
function renderReports() {
    const statusLabel = { approved: 'Одобрен', pending: 'На проверке', rejected: 'Отклонён' };
    const statusClass = { approved: 'report-status-approved', pending: 'report-status-pending', rejected: 'report-status-rejected' };

    document.getElementById('reports-table-body').innerHTML = reports.map(r => `
        <tr style="cursor:pointer;" onclick="navigate('report-detail','${r.id}')">
            <td class="px-4 text-muted small">#R-${r.id}</td>
            <td>
                <div class="fw-semibold small">${r.task}</div>
            </td>
            <td class="text-muted small d-none d-md-table-cell">${r.date}</td>
            <td class="text-muted small d-none d-md-table-cell">${r.hours} ч.</td>
            <td><span class="badge ${statusClass[r.status]} px-2 py-1">${statusLabel[r.status]}</span></td>
            <td class="text-end pe-4">
                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="navigate('report-detail','${r.id}');event.stopPropagation()">
                    <i class="bi bi-eye"></i>
                </button>
            </td>
        </tr>
    `).join('');
}

// ==================== PHOTO PREVIEW ====================
function previewPhotos(input) {
    const preview = document.getElementById('photo-preview');
    preview.innerHTML = '';
    Array.from(input.files).forEach(file => {
        const reader = new FileReader();
        reader.onload = e => {
            preview.innerHTML += `
                <div class="col-4 col-sm-3">
                    <img src="${e.target.result}" class="img-fluid rounded-3" style="height:90px;object-fit:cover;width:100%;">
                </div>`;
        };
        reader.readAsDataURL(file);
    });
}

// ==================== TOAST ====================
function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    const body = document.getElementById('toast-body');
    toast.className = `toast align-items-center text-white border-0 bg-${type === 'success' ? 'success' : 'danger'}`;
    body.textContent = msg;
    const bsToast = new bootstrap.Toast(toast, { delay: 3000 });
    bsToast.show();
}

function submitReport() {
    showToast('Отчёт успешно отправлен на проверку!', 'success');
    setTimeout(() => navigate('reports'), 1000);
}

function saveProfile() {
    showToast('Профиль успешно сохранён!', 'success');
    setTimeout(() => navigate('profile'), 800);
}

// ==================== INIT ====================
renderAvailableTasks();
renderMyTasks('all');
renderReports();
</script>
</body>
</html>
