<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnimalShelter CRM — Волонтёрский кабинет</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: #fff;
            border-right: 1px solid #dee2e6;
            position: fixed;
            top: 0; left: 0;
            z-index: 1040;
            transition: transform 0.3s ease;
            display: flex;
            flex-direction: column;
        }
        .sidebar-brand {
            padding: 20px 24px 16px;
            border-bottom: 1px solid #dee2e6;
        }
        .sidebar-nav { padding: 12px 0; flex: 1; }
        .sidebar-nav .nav-link {
            color: #495057;
            padding: 10px 24px;
            font-size: 0.9rem;
            border-radius: 0;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.15s;
        }
        .sidebar-nav .nav-link:hover { background: #fff3cd; color: #fd7e14; }
        .sidebar-nav .nav-link.active { background: #fff3cd; color: #fd7e14; font-weight: 600; border-left: 3px solid #ffc107; }
        .sidebar-nav .nav-section {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #adb5bd;
            padding: 16px 24px 6px;
        }
        .main-content {
            margin-left: 260px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .topbar {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 12px 28px;
            position: sticky;
            top: 0;
            z-index: 1030;
        }
        .page { display: none; }
        .page.active { display: block; }
        .stat-card { border: none; border-radius: 16px; }
        .avatar-circle {
            width: 80px; height: 80px;
            background: linear-gradient(135deg, #ffc107, #fd7e14);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; color: #fff; font-weight: 700;
        }
        .avatar-sm {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #ffc107, #fd7e14);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.9rem; color: #fff; font-weight: 700;
            flex-shrink: 0;
        }
        .task-card { transition: transform 0.15s, box-shadow 0.15s; cursor: pointer; }
        .task-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.1) !important; }
        .badge-priority-high { background: #f8d7da; color: #842029; }
        .badge-priority-med { background: #fff3cd; color: #664d03; }
        .badge-priority-low { background: #d1e7dd; color: #0a3622; }
        .progress { height: 6px; border-radius: 4px; }
        .notification-dot {
            width: 8px; height: 8px;
            background: #dc3545;
            border-radius: 50%;
            position: absolute;
            top: 2px; right: 2px;
        }
        .report-status-approved { background: #d1e7dd; color: #0a3622; }
        .report-status-pending { background: #fff3cd; color: #664d03; }
        .report-status-rejected { background: #f8d7da; color: #842029; }
        .photo-upload-area {
            border: 2px dashed #dee2e6;
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
        }
        .photo-upload-area:hover { border-color: #ffc107; background: #fffdf0; }
        .sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid #dee2e6;
        }
        .sidebar-overlay {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 1039;
        }
        .breadcrumb-item a { color: #fd7e14; text-decoration: none; }
        .timeline-item { position: relative; padding-left: 28px; }
        .timeline-item::before {
            content: '';
            position: absolute;
            left: 8px; top: 24px; bottom: -8px;
            width: 2px; background: #dee2e6;
        }
        .timeline-item:last-child::before { display: none; }
        .timeline-dot {
            position: absolute;
            left: 0; top: 16px;
            width: 18px; height: 18px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.55rem;
        }
        .skill-badge { font-size: 0.8rem; padding: 6px 12px; border-radius: 20px; }
    </style>
</head>
<body>

<!-- Sidebar Overlay (mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <div class="d-flex align-items-center gap-2">
            <div class="bg-warning rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                <i class="bi bi-heart-fill text-white"></i>
            </div>
            <div>
                <div class="fw-bold" style="font-size:0.95rem;line-height:1.2;">AnimalShelter</div>
                <div class="text-muted" style="font-size:0.7rem;">Волонтёрский кабинет</div>
            </div>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section">Главное</div>
        <a href="#" class="nav-link active" data-page="dashboard">
            <i class="bi bi-grid-1x2-fill"></i> Дашборд
        </a>
        <a href="#" class="nav-link" data-page="notifications">
            <i class="bi bi-bell-fill"></i> Уведомления
            <span class="badge bg-danger ms-auto" style="font-size:0.65rem;">3</span>
        </a>

        <div class="nav-section">Задачи</div>
        <a href="#" class="nav-link" data-page="tasks-available">
            <i class="bi bi-list-task"></i> Доступные задачи
        </a>
        <a href="#" class="nav-link" data-page="tasks-my">
            <i class="bi bi-check2-square"></i> Мои задачи
        </a>

        <div class="nav-section">Отчёты</div>
        <a href="#" class="nav-link" data-page="reports">
            <i class="bi bi-journal-text"></i> История отчётов
        </a>

        <div class="nav-section">Аккаунт</div>
        <a href="#" class="nav-link" data-page="profile">
            <i class="bi bi-person-fill"></i> Мой профиль
        </a>
        <a href="#" class="nav-link" data-page="profile-edit">
            <i class="bi bi-pencil-fill"></i> Редактировать профиль
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="d-flex align-items-center gap-2">
            <div class="avatar-sm" style="width:32px;height:32px;font-size:0.8rem;">АК</div>
            <div style="min-width:0;">
                <div class="fw-semibold text-truncate" style="font-size:0.82rem;">Алексей Козлов</div>
                <div class="text-muted text-truncate" style="font-size:0.72rem;">Старший волонтёр</div>
            </div>
            <a href="#" class="ms-auto text-muted" title="Выйти"><i class="bi bi-box-arrow-right"></i></a>
        </div>
    </div>
</aside>

<!-- Main Content -->
<div class="main-content">
    <!-- Topbar -->
    <div class="topbar d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-light d-lg-none" onclick="openSidebar()">
            <i class="bi bi-list fs-5"></i>
        </button>
        <nav aria-label="breadcrumb" class="me-auto">
            <ol class="breadcrumb mb-0 small" id="breadcrumb">
                <li class="breadcrumb-item active">Дашборд</li>
            </ol>
        </nav>
        <div class="position-relative">
            <button class="btn btn-sm btn-light position-relative" onclick="navigate('notifications')">
                <i class="bi bi-bell fs-6"></i>
                <span class="notification-dot"></span>
            </button>
        </div>
        <div class="avatar-sm" style="width:34px;height:34px;font-size:0.8rem;cursor:pointer;" onclick="navigate('profile')">АК</div>
    </div>

    <!-- Pages -->
    <div class="flex-grow-1 p-3 p-lg-4" style="max-width:1200px; width:100%;">

        <!-- ===== DASHBOARD ===== -->
        <div class="page active" id="page-dashboard">
            <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
                <div>
                    <h4 class="fw-bold mb-1">Добро пожаловать, Алексей! 👋</h4>
                    <p class="text-muted mb-0 small">Пятница, 13 июня 2025 · Вы сделали 3 дела на этой неделе</p>
                </div>
                <button class="btn btn-warning text-white rounded-pill px-4" onclick="navigate('tasks-available')">
                    <i class="bi bi-plus-lg me-2"></i>Взять задачу
                </button>
            </div>

            <!-- Stats Row -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-lg-3">
                    <div class="card stat-card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted small">Активных задач</span>
                                <div class="bg-warning bg-opacity-10 text-warning rounded-2 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                    <i class="bi bi-hourglass-split"></i>
                                </div>
                            </div>
                            <div class="fs-3 fw-bold">4</div>
                            <div class="small text-success"><i class="bi bi-arrow-up"></i> +1 на этой неделе</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="card stat-card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted small">Выполнено всего</span>
                                <div class="bg-success bg-opacity-10 text-success rounded-2 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                    <i class="bi bi-check-circle-fill"></i>
                                </div>
                            </div>
                            <div class="fs-3 fw-bold">23</div>
                            <div class="small text-muted">С начала участия</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="card stat-card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted small">Часов волонтёрства</span>
                                <div class="bg-info bg-opacity-10 text-info rounded-2 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                    <i class="bi bi-clock-fill"></i>
                                </div>
                            </div>
                            <div class="fs-3 fw-bold">148</div>
                            <div class="small text-muted">Суммарно</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="card stat-card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted small">Рейтинг</span>
                                <div class="bg-danger bg-opacity-10 text-danger rounded-2 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                    <i class="bi bi-star-fill"></i>
                                </div>
                            </div>
                            <div class="fs-3 fw-bold">4.8</div>
                            <div class="small text-warning"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- My Tasks Widget -->
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-0 pt-4 px-4 pb-2 d-flex align-items-center justify-content-between">
                            <h6 class="fw-bold mb-0">Мои активные задачи</h6>
                            <a href="#" class="small text-warning text-decoration-none" onclick="navigate('tasks-my');return false;">Все задачи →</a>
                        </div>
                        <div class="card-body px-4 pt-2">
                            <div class="d-flex align-items-start gap-3 py-3 border-bottom task-card rounded-3 px-2" onclick="navigate('task-detail','1')">
                                <div class="bg-warning bg-opacity-10 text-warning rounded-2 d-flex align-items-center justify-content-center flex-shrink-0" style="width:40px;height:40px;">
                                    <i class="bi bi-droplet-fill"></i>
                                </div>
                                <div class="flex-grow-1 min-width-0">
                                    <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                        <span class="fw-semibold" style="font-size:0.9rem;">Кормление собак, вольер А</span>
                                        <span class="badge badge-priority-high" style="font-size:0.65rem;">Высокий</span>
                                    </div>
                                    <div class="text-muted small mb-2"><i class="bi bi-calendar3 me-1"></i>Срок: 14 июня 2025</div>
                                    <div class="progress">
                                        <div class="progress-bar bg-warning" style="width:60%"></div>
                                    </div>
                                    <div class="text-muted" style="font-size:0.7rem;margin-top:4px;">60% выполнено</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-start gap-3 py-3 border-bottom task-card rounded-3 px-2" onclick="navigate('task-detail','2')">
                                <div class="bg-success bg-opacity-10 text-success rounded-2 d-flex align-items-center justify-content-center flex-shrink-0" style="width:40px;height:40px;">
                                    <i class="bi bi-person-walking"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                        <span class="fw-semibold" style="font-size:0.9rem;">Выгул собак (утренний)</span>
                                        <span class="badge badge-priority-med" style="font-size:0.65rem;">Средний</span>
                                    </div>
                                    <div class="text-muted small mb-2"><i class="bi bi-calendar3 me-1"></i>Срок: 15 июня 2025</div>
                                    <div class="progress">
                                        <div class="progress-bar bg-success" style="width:30%"></div>
                                    </div>
                                    <div class="text-muted" style="font-size:0.7rem;margin-top:4px;">30% выполнено</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-start gap-3 py-3 task-card rounded-3 px-2" onclick="navigate('task-detail','3')">
                                <div class="bg-info bg-opacity-10 text-info rounded-2 d-flex align-items-center justify-content-center flex-shrink-0" style="width:40px;height:40px;">
                                    <i class="bi bi-camera-fill"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                        <span class="fw-semibold" style="font-size:0.9rem;">Фотосессия для кошек</span>
                                        <span class="badge badge-priority-low" style="font-size:0.65rem;">Низкий</span>
                                    </div>
                                    <div class="text-muted small mb-2"><i class="bi bi-calendar3 me-1"></i>Срок: 18 июня 2025</div>
                                    <div class="progress">
                                        <div class="progress-bar bg-info" style="width:10%"></div>
                                    </div>
                                    <div class="text-muted" style="font-size:0.7rem;margin-top:4px;">10% выполнено</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="col-lg-5 d-flex flex-column gap-4">
                    <!-- Notifications -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 pt-4 px-4 pb-2 d-flex align-items-center justify-content-between">
                            <h6 class="fw-bold mb-0">Уведомления</h6>
                            <span class="badge bg-danger" style="font-size:0.65rem;">3 новых</span>
                        </div>
                        <div class="card-body px-4 pt-0">
                            <div class="d-flex gap-3 py-2 border-bottom">
                                <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;">
                                    <i class="bi bi-check2 small"></i>
                                </div>
                                <div>
                                    <div class="small fw-semibold">Отчёт одобрен</div>
                                    <div class="text-muted" style="font-size:0.75rem;">Отчёт по задаче «Уборка вольеров» одобрен</div>
                                    <div class="text-muted" style="font-size:0.7rem;">2 часа назад</div>
                                </div>
                            </div>
                            <div class="d-flex gap-3 py-2 border-bottom">
                                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;">
                                    <i class="bi bi-exclamation small"></i>
                                </div>
                                <div>
                                    <div class="small fw-semibold">Приближается срок</div>
                                    <div class="text-muted" style="font-size:0.75rem;">Задача «Кормление» — завтра</div>
                                    <div class="text-muted" style="font-size:0.7rem;">5 часов назад</div>
                                </div>
                            </div>
                            <div class="d-flex gap-3 py-2">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;">
                                    <i class="bi bi-person small"></i>
                                </div>
                                <div>
                                    <div class="small fw-semibold">Новая задача</div>
                                    <div class="text-muted" style="font-size:0.75rem;">Добавлена задача для вашей группы</div>
                                    <div class="text-muted" style="font-size:0.7rem;">Вчера, 18:30</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Progress -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3">Прогресс за месяц</h6>
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">Выполнено задач</span>
                                    <span class="fw-semibold">8 / 10</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-success" style="width:80%"></div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">Часов отработано</span>
                                    <span class="fw-semibold">32 / 40</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-warning" style="width:80%"></div>
                                </div>
                            </div>
                            <div>
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">Одобренных отчётов</span>
                                    <span class="fw-semibold">7 / 8</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar bg-info" style="width:87%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== AVAILABLE TASKS ===== -->
        <div class="page" id="page-tasks-available">
            <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
                <div>
                    <h4 class="fw-bold mb-1">Доступные задачи</h4>
                    <p class="text-muted mb-0 small">Задачи, которые можно взять в работу</p>
                </div>
                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">12 задач доступно</span>
            </div>

            <!-- Filters -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-3">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" class="form-control border-start-0" placeholder="Поиск задач...">
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <select class="form-select">
                                <option>Все типы</option>
                                <option>Уход</option>
                                <option>Выгул</option>
                                <option>Фото</option>
                                <option>Уборка</option>
                            </select>
                        </div>
                        <div class="col-6 col-md-2">
                            <select class="form-select">
                                <option>Приоритет</option>
                                <option>Высокий</option>
                                <option>Средний</option>
                                <option>Низкий</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select">
                                <option>Все группы</option>
                                <option>Группа А</option>
                                <option>Группа Б</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-outline-secondary w-100"><i class="bi bi-funnel me-1"></i>Фильтр</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3" id="available-tasks-list">
                <!-- Tasks rendered by JS -->
            </div>
        </div>

        <!-- ===== MY TASKS ===== -->
        <div class="page" id="page-tasks-my">
            <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
                <div>
                    <h4 class="fw-bold mb-1">Мои задачи</h4>
                    <p class="text-muted mb-0 small">Задачи, взятые вами в работу</p>
                </div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-pills mb-4 gap-1">
                <li class="nav-item">
                    <button class="nav-link active" onclick="filterMyTasks('all',this)">Все <span class="badge bg-secondary ms-1">4</span></button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" onclick="filterMyTasks('inprogress',this)">В работе <span class="badge bg-warning text-dark ms-1">3</span></button>
                </li>
